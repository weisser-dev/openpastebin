# OpenPasteBin Environment Variables
# Copy this file to .env and fill in your values

# Backend Configuration
NODE_ENV=production
PORT=5000
MONGO_URI=mongodb://mongodb:27017/openpastebin

# Encryption Key (AES-256-GCM)
# Generate a secure 32-byte hex key (64 characters):
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# CRITICAL: Keep this key secret and backed up - lost keys = unrecoverable data
ENCRYPTION_KEY=your_32_byte_hex_encryption_key_here_64_characters_long
